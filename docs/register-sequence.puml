@startuml
title Sơ đồ tuần tự - Ca sử dụng đăng ký tài khoản

actor "Người dùng" as User
boundary "_RegisterScreenState" as RegisterScreenState
control "AuthApiService" as AuthApiService
control "ClientController" as ClientController
control "ClientServiceImpl" as ClientServiceImpl
control "ClientMapper" as ClientMapper
database "FileRepository" as FileRepository
control "PasswordEncoder" as PasswordEncoder
database "ClientRepository" as ClientRepository
control "OtpCodeUtil" as OtpCodeUtil
database "RedisTemplate" as RedisTemplate
control "EmailUtil" as EmailUtil
control "JavaMailSender" as JavaMailSender
control "Navigator" as Navigator

User -> RegisterScreenState: 1: nhập thông tin và bấm Đăng ký
activate RegisterScreenState

RegisterScreenState -> RegisterScreenState: 2: _submitRegister()
activate RegisterScreenState

RegisterScreenState -> AuthApiService: 3: gọi
activate AuthApiService
AuthApiService -> AuthApiService: 4: register(RegisterRequest)
activate AuthApiService

AuthApiService -> ClientController: 5: gọi API POST /client/register
activate ClientController
ClientController -> ClientController: 6: register(RegisterRequest)
activate ClientController

ClientController -> ClientServiceImpl: 7: gọi
activate ClientServiceImpl
ClientServiceImpl -> ClientServiceImpl: 8: register(RegisterRequest)
activate ClientServiceImpl

ClientServiceImpl -> ClientMapper: 9: gọi
activate ClientMapper
ClientMapper -> ClientMapper: 10: registerRequestToEntity(RegisterRequest)
activate ClientMapper
deactivate ClientMapper
ClientMapper --> ClientServiceImpl: 11: trả về kết quả
deactivate ClientMapper

ClientServiceImpl -> FileRepository: 12: gọi
activate FileRepository
FileRepository -> FileRepository: 13: findById(4L)
activate FileRepository
deactivate FileRepository
FileRepository --> ClientServiceImpl: 14: trả về kết quả
deactivate FileRepository

ClientServiceImpl -> PasswordEncoder: 15: gọi
activate PasswordEncoder
PasswordEncoder -> PasswordEncoder: 16: encode(password)
activate PasswordEncoder
deactivate PasswordEncoder
PasswordEncoder --> ClientServiceImpl: 17: trả về kết quả
deactivate PasswordEncoder

ClientServiceImpl -> ClientRepository: 18: gọi
activate ClientRepository
ClientRepository -> ClientRepository: 19: findByEmail(email)
activate ClientRepository
deactivate ClientRepository
ClientRepository --> ClientServiceImpl: 20: trả về kết quả
deactivate ClientRepository

ClientServiceImpl -> ClientRepository: 21: gọi
activate ClientRepository
ClientRepository -> ClientRepository: 22: save(Client)
activate ClientRepository
deactivate ClientRepository
ClientRepository --> ClientServiceImpl: 23: trả về kết quả
deactivate ClientRepository

ClientServiceImpl -> OtpCodeUtil: 24: gọi
activate OtpCodeUtil
OtpCodeUtil -> OtpCodeUtil: 25: generateOtpCode()
activate OtpCodeUtil
deactivate OtpCodeUtil
OtpCodeUtil --> ClientServiceImpl: 26: trả về kết quả
deactivate OtpCodeUtil

ClientServiceImpl -> RedisTemplate: 27: gọi
activate RedisTemplate
RedisTemplate -> RedisTemplate: 28: opsForValue().set(email, code, 5, TimeUnit.MINUTES)
activate RedisTemplate
deactivate RedisTemplate
RedisTemplate --> ClientServiceImpl: 29: trả về kết quả
deactivate RedisTemplate

ClientServiceImpl -> EmailUtil: 30: gọi
activate EmailUtil
EmailUtil -> EmailUtil: 31: sendOtpEmail(email, code, title, message, 5)
activate EmailUtil

EmailUtil -> JavaMailSender: 32: gọi
activate JavaMailSender
JavaMailSender -> JavaMailSender: 33: send(mimeMessage)
activate JavaMailSender
deactivate JavaMailSender
JavaMailSender --> EmailUtil: 34: trả về kết quả
deactivate JavaMailSender

deactivate EmailUtil
EmailUtil --> ClientServiceImpl: 35: trả về kết quả
deactivate EmailUtil

deactivate ClientServiceImpl
ClientServiceImpl --> ClientController: 36: trả về kết quả
deactivate ClientServiceImpl

deactivate ClientController
ClientController --> AuthApiService: 37: trả về kết quả
deactivate ClientController

deactivate AuthApiService
AuthApiService --> RegisterScreenState: 38: trả về kết quả
deactivate AuthApiService

RegisterScreenState -> Navigator: 39: gọi
activate Navigator
Navigator -> Navigator: 40: pushNamed(AppRoutes.verifyOtp, VerifyOtpArgs)
activate Navigator
deactivate Navigator
Navigator --> RegisterScreenState: 41: trả về kết quả
deactivate Navigator

deactivate RegisterScreenState

RegisterScreenState --> User: 42: điều hướng đến màn hình xác thực OTP
deactivate RegisterScreenState

@enduml
